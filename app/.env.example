APP_ENV=development
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_OR_EXTENSION_SUCCESS_URL=chrome-extension://<extension-id>/success.html
CHROME_EXTENSION_ID=<extension-id>

DATABASE_URL=postgresql+psycopg://leetsave:leetsave@localhost:5432/leetcode_github_sync

JWT_SECRET_KEY=replace-me
JWT_ALGORITHM=HS256
SESSION_EXPIRE_MINUTES=10080

GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback
GITHUB_DEFAULT_REPO_NAME=leetcode-problems
GITHUB_DEFAULT_BRANCH=main

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=replace-me
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-1.5-flash

TOKEN_ENCRYPTION_KEY=replace-me

CORS_ALLOWED_ORIGINS=http://localhost:3000,chrome-extension://<extension-id>
